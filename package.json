{
  "name": "storage",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "description": "桌面文件收纳工具",
  "author": "Desktop Storage App",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "node close-ports.js && chcp 65001 && npm run dev",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/runtime": "^7.29.2",
    "@babel/runtime-corejs3": "^7.29.2",
    "antd": "^6.3.5",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "windows-shortcuts": "^0.1.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "terser": "^5.27.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.29.1",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "com.storage.app",
    "productName": "桌面收纳",
    "directories": {
      "output": "dist-electron"
    },
    "asar": true,
    "compression": "maximum",
    "defaultArch": "x64",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "桌面收纳"
    },
    "portable": {
      "artifactName": "桌面收纳-Portable-${version}.${ext}"
    }
  }
}
