{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "StorageApp",
  "version": "1.1.1",
  "identifier": "com.desktopstorage.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "桌面收纳",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true,
        "url": "index.html",
        "decorations": false,
        "visible": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: file: https:; font-src 'self' data:; connect-src 'self' ipc.localhost ipc.http.localhost ipc.http.127.0.0.1"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "installMode": "currentUser",
        "languages": [
          "English"
        ],
        "displayLanguageSelector": false,
        "compression": "lzma"
      },
      "wix": {
        "language": [
          "en-US"
        ]
      }
    },
    "shortDescription": "桌面文件收纳工具",
    "longDescription": "一个简洁高效的桌面文件收纳管理工具，帮助用户整理和管理桌面文件。",
    "category": "Utility",
    "publisher": "Desktop Storage",
    "copyright": "Copyright © 2024 Desktop Storage"
  },
  "plugins": {
    "store": {
      "path": "data/local"
    },
    "dialog": null,
    "updater": {
      "endpoints": [
        "https://github.com/Yqxnice/storage/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYwMDYxOTBFOUVEOTI5MUIKUldRYktkbWVEaGtHOE5xMFZhNEtyV1l3QW5TWC9aS0JpVEhhT29pK2hsQWRmSFhReVA5anhSejgK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
